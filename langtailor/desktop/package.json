{
  "name": "langtailor-desktop",
  "version": "0.2.0",
  "description": "LangTailor — Electron IDE for LangGraph",
  "main": "dist/main/index.js",
  "private": true,
  "type": "module",
  "scripts": {
    "build:main": "tsc -p tsconfig.main.json",
    "build:renderer": "vite build --config ../../vite.desktop.config.ts",
    "build": "npm run build:renderer && npm run build:main",
    "postinstall": "node scripts/ensure-electron.cjs",
    "ensure-electron": "node scripts/ensure-electron.cjs",
    "start": "electron .",
    "dev": "npm run build && electron .",
    "dist": "npm run build && electron-builder --config electron-builder.yml",
    "dist:win": "npm run build && electron-builder --win --config electron-builder.yml",
    "dist:mac": "npm run build && electron-builder --mac --config electron-builder.yml"
  },
  "dependencies": {
    "chokidar": "^4.0.3",
    "electron-store": "^10.1.0",
    "electron-updater": "^6.6.2",
    "node-pty": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^22.15.0",
    "electron": "^36.3.2",
    "electron-builder": "^26.0.12",
    "typescript": "~5.8.3"
  }
}
