{
  "name": "langtailor-canvas",
  "displayName": "LangTailor Canvas",
  "description": "Visual LangGraph canvas — design agent workflows and export Python, built into LangTailor.",
  "version": "0.1.2",
  "publisher": "langstitch",
  "license": "MIT",
  "icon": "icon.png",
  "homepage": "https://langtailor.langstitch.com",
  "bugs": {
    "url": "https://github.com/vijayptiwari/LangStitch/issues"
  },
  "galleryBanner": {
    "color": "#06080f",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/vijayptiwari/LangStitch.git"
  },
  "engines": {
    "vscode": "^1.90.0"
  },
  "categories": ["Visualization", "Other"],
  "keywords": ["langgraph", "langchain", "agents", "langstitch", "langtailor"],
  "main": "./dist/extension.js",
  "contributes": {
    "customEditors": [
      {
        "viewType": "langtailor.canvas",
        "displayName": "LangTailor Canvas",
        "selector": [
          {
            "filenamePattern": "*.langstitch.json"
          }
        ],
        "priority": "default"
      }
    ],
    "commands": [
      {
        "command": "langtailor.newGraph",
        "title": "LangTailor: New Graph"
      }
    ]
  },
  "scripts": {
    "build:webview": "vite build --config ../../vite.webview.config.ts",
    "compile": "tsc -p ./",
    "build": "npm run build:webview && npm run compile",
    "package": "vsce package --no-dependencies --out ../../dist-langtailor"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/vscode": "^1.90.0",
    "@vscode/vsce": "^3.2.0",
    "typescript": "~5.8.3"
  }
}
