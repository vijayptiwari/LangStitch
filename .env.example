# LangStitch Platform API — copy to `.env` for Docker Compose / local auth.
# Auth is OFF by default (single shared workspace, no login).

LANGSTITCH_WORKSPACE=/data/workspaces
LANGSTITCH_AUTH_ENABLED=false
LANGSTITCH_SESSION_SECRET=change-me-to-a-long-random-string
LANGSTITCH_COOKIE_SECURE=false
LANGSTITCH_COOKIE_SAMESITE=lax
LANGSTITCH_SESSION_MAX_AGE=604800
LANGSTITCH_FRONTEND_URL=http://localhost:5173
LANGSTITCH_API_BASE_URL=

MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=langstitch
MYSQL_PASSWORD=
MYSQL_DATABASE=langstitch

GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

LANGCHAIN_API_KEY=
