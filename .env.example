# LangStitch Platform API — copy to `.env` for Docker Compose / local auth.
# Auth is OFF by default (single shared workspace, no login).

LANGSTITCH_WORKSPACE=/data/workspaces
LANGSTITCH_AUTH_ENABLED=false
LANGSTITCH_SESSION_SECRET=change-me-to-a-long-random-string
LANGSTITCH_COOKIE_SECURE=false
LANGSTITCH_COOKIE_SAMESITE=lax
LANGSTITCH_SESSION_MAX_AGE=604800
LANGSTITCH_FRONTEND_URL=http://localhost:5173
LANGSTITCH_API_BASE_URL=

# ─── Marketplace subdomain (marketplace.langstitch.com) ───
# Public URL of the standalone marketplace site. When set it is allowed as a
# CORS origin and as a post-login return target.
LANGSTITCH_MARKETPLACE_URL=
# Share the login session across subdomains. Set to the parent domain so the
# session cookie set on langstitch.com is also sent to marketplace.langstitch.com.
LANGSTITCH_COOKIE_DOMAIN=
# Extra browser origins allowed to call the API (comma-separated). The IDE
# (LANGSTITCH_FRONTEND_URL) and marketplace (LANGSTITCH_MARKETPLACE_URL) are
# always allowed; only add others here.
LANGSTITCH_CORS_ORIGINS=
#
# Production example (uncomment + adjust):
# LANGSTITCH_FRONTEND_URL=https://langstitch.com
# LANGSTITCH_MARKETPLACE_URL=https://marketplace.langstitch.com
# LANGSTITCH_API_BASE_URL=https://langstitch.com
# LANGSTITCH_COOKIE_DOMAIN=.langstitch.com
# LANGSTITCH_COOKIE_SECURE=true

# Marketplace artifact storage (uploaded .vsix files when auth is on)
LANGSTITCH_ARTIFACTS_ROOT=/data/artifacts
LANGSTITCH_MAX_VSIX_BYTES=52428800

# Review workflow — who can approve submissions and where notifications go
LANGSTITCH_ADMIN_EMAILS=dev@langstitch.com
LANGSTITCH_REVIEW_EMAIL=dev@langstitch.com

# SMTP (optional — without these, review emails are logged instead of sent)
# Set LANGSTITCH_SMTP_PROVIDER to a preset: sendgrid | gmail | mailgun | ses | custom
LANGSTITCH_SMTP_PROVIDER=custom
LANGSTITCH_SMTP_HOST=
LANGSTITCH_SMTP_PORT=587
LANGSTITCH_SMTP_USER=
LANGSTITCH_SMTP_PASSWORD=
LANGSTITCH_SMTP_USE_TLS=true
LANGSTITCH_SMTP_USE_SSL=false
LANGSTITCH_SMTP_FROM=LangStitch Marketplace <no-reply@langstitch.com>

# Database (required when LANGSTITCH_AUTH_ENABLED=true)
# For Docker Compose, leave MYSQL_HOST unset in .env — compose sets MYSQL_HOST=db.
LANGSTITCH_DATABASE_URL=
MYSQL_HOST=
MYSQL_PORT=3306
MYSQL_USER=langstitch
MYSQL_PASSWORD=langstitch
MYSQL_DATABASE=langstitch
MYSQL_ROOT_PASSWORD=rootpassword

# OAuth providers (configure at least one when auth is on)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=
MICROSOFT_TENANT_ID=common
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# E2E auth bypass for Playwright (never enable in production)
# LANGSTITCH_E2E_AUTH=true
LANGSTITCH_DESKTOP_TOKEN_MAX_AGE=2592000
LANGSTITCH_DESKTOP_URL_SCHEME=langtailor

LANGCHAIN_API_KEY=
